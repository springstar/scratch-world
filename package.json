{
	"name": "scratch-world",
	"version": "0.1.0",
	"description": "Chat-driven AI agent for creating and evolving persistent 3D worlds",
	"type": "module",
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"dev": "tsx src/index.ts",
		"check": "tsc --noEmit && biome check src",
		"lint": "biome lint src",
		"format": "biome format --write src",
		"test": "vitest --run",
		"test:watch": "vitest",
		"analytics": "tsx scripts/harness-analytics.ts",
		"bench": "tsx scripts/harness-bench.ts",
		"compare": "tsx scripts/harness-compare.ts"
	},
	"dependencies": {
		"@hono/node-server": "^1.19.11",
		"@mariozechner/pi-agent-core": "^0.58.4",
		"@mariozechner/pi-ai": "^0.58.4",
		"@sinclair/typebox": "^0.34.33",
		"@types/sharp": "^0.31.1",
		"better-sqlite3": "^11.10.0",
		"dotenv": "^16.5.0",
		"grammy": "^1.36.3",
		"hono": "^4.12.8",
		"sharp": "^0.34.5",
		"ws": "^8.19.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.0.0",
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^22.0.0",
		"@types/ws": "^8.18.1",
		"tsx": "^4.20.3",
		"typescript": "^5.7.3",
		"vitest": "^3.0.0"
	},
	"engines": {
		"node": ">=20.0.0"
	}
}
