# Channel adapters (telegram | stdin)
# Use CHANNEL=stdin for local testing without a Telegram bot token
CHANNEL=telegram
TELEGRAM_BOT_TOKEN=

# 3D provider (marble | stub)
PROVIDER=stub
MARBLE_API_KEY=
MARBLE_API_URL=

# Storage (sqlite:./dev.db or postgres://user:pass@host:5432/db)
DATABASE_URL=sqlite:./dev.db

# LLM
ANTHROPIC_API_KEY=

# Viewer API (backend HTTP + WebSocket server)
VIEWER_API_PORT=3001

# Viewer App base URL (used to build viewer links sent to users)
# Dev: Vite dev server proxies API calls → set to Vite port (5173)
# Prod: set to your deployed viewer domain
VIEWER_BASE_URL=http://localhost:5173

# Viewer App (set VITE_API_BASE only when viewer is deployed separately from backend)
# VITE_API_BASE=https://your-backend.example.com
